generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── Users & Roles ─────────────────────────────────────────────────────────────

enum UserRole {
  Admin
  Editor
  Viewer
}

enum NotifyChannel {
  Email
  Telegram
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String
  passwordHash  String
  role          UserRole @default(Viewer)
  isActive      Boolean  @default(true)
  // Set when a user leaves the company (YYYY-MM-DD, same form as Entry.date).
  // Entries after this date are removed on termination; entries up to and
  // including it are kept for history/audit purposes.
  exitDate      String?
  // Order in the yearly rotation automation (lower = earlier)
  rotationOrder Int      @default(0)

  // Notification settings
  notifyEnabled  Boolean @default(false)
  // At least one of notifyEmail/notifyTelegram must be true when notifyEnabled;
  // enforced in the Server Actions, not the schema.
  notifyEmail    Boolean @default(true)
  notifyTelegram Boolean @default(false)
  notifyWeekday  Int     @default(1) // 0=Sun ... 6=Sat, default Monday
  notifyHour     Int     @default(7) // hour (0-23) in the app timezone (NOTIFY_TIMEZONE, default Europe/Zurich)
  notifyMinute   Int     @default(0) // minute (0-59, 5-minute steps) in the app timezone
  telegramChatId String?

  // Bearer token for the personal iCal feed. Created as 32 random bytes
  // (base64url) in the app; the cuid() default is only a fallback for rows
  // created outside it. Rotatable via the dashboard ("Link neu generieren").
  icalToken           String  @unique @default(cuid())
  // Whether the personal iCal feed includes Ferien (F) entries in addition
  // to S-Dienst. Defaults to true to preserve the feed's prior behavior.
  icalIncludeVacation Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries             Entry[]
  auditLogs           AuditLog[]
  notifications       PendingNotification[]
  passwordResetTokens PasswordResetToken[]
  swapRequestsFrom    SwapRequest[]         @relation("SwapRequestsFrom")
  swapRequestsTo      SwapRequest[]         @relation("SwapRequestsTo")

  @@index([rotationOrder])
}

// ── Duty swap requests ─────────────────────────────────────────────────────────

enum SwapRequestStatus {
  Pending
  Accepted
  Declined
  Cancelled
  // Auto-closed because a sibling request in the same broadcast group was accepted first.
  Superseded
}

model SwapRequest {
  id         Int               @id @default(autoincrement())
  // Requester who currently holds the S-duties …
  fromUserId Int
  // … and the colleague asked to take them over.
  toUserId   Int
  // JSON array of YYYY-MM-DD strings (the S-duty days to hand over).
  dates      String
  comment    String?
  status     SwapRequestStatus @default(Pending)
  // Shared across the N rows created by a "broadcast to everyone" request, so
  // accepting/cancelling one can close out the rest of the group.
  groupId    String?
  createdAt  DateTime          @default(now())
  decidedAt  DateTime?

  fromUser User @relation("SwapRequestsFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("SwapRequestsTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([groupId])
}

// ── Password reset ─────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  // SHA-256 of the raw token; the raw token only ever exists in the email
  // link, so a leaked DB row can't be used to reset a password.
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Duty/absence types ─────────────────────────────────────────────────────────

enum EntryType {
  S // Sanitaet (duty)
  F // Ferien (vacation)
  G // geschaeftliche Absenz (business absence)
  C // Kompensieren (compensate)
  M // Militaer (military)
  K // Kurzarbeit (short-time work)
  TZ // Teilzeit (part-time)
  A // Ausbildung (training)
  H // Homeoffice
}

enum EntrySource {
  Automatic
  Manual
  Swap
}

model Entry {
  id      Int         @id @default(autoincrement())
  userId  Int
  date    String // YYYY-MM-DD (local calendar day)
  type    EntryType
  source  EntrySource @default(Manual)
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([type])
}

// ── Holidays ────────────────────────────────────────────────────────────────────

model Holiday {
  id     Int     @id @default(autoincrement())
  date   String // YYYY-MM-DD
  name   String
  canton String?
  year   Int

  @@unique([date, canton])
  @@index([year])
}

// ── Audit log ──────────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  userName   String
  action     String // CREATE | UPDATE | DELETE | MOVE | AUTOMATIC | SETTINGS
  entityType String // Entry | Holiday | User | Settings
  entityId   Int?
  details    String? // JSON: { before, after, ... }
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ── System settings (singleton) ─────────────────────────────────────────────────

model SystemSettings {
  id Int @id @default(1)

  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPassword    String? // AES-encrypted
  smtpFromName    String?
  smtpFromAddress String? // optional envelope/header From address, if different from smtpUser

  telegramBotToken String? // AES-encrypted

  defaultCanton String @default("BE")

  updatedAt DateTime @updatedAt
}

// ── Notification queue ──────────────────────────────────────────────────────────

model PendingNotification {
  id        Int           @id @default(autoincrement())
  userId    Int
  channel   NotifyChannel
  subject   String
  body      String
  createdAt DateTime      @default(now())
  sentAt    DateTime?
  failedAt  DateTime?
  error     String?
  // Delivery attempts so far; rows at NOTIFY_MAX_ATTEMPTS are no longer retried.
  attempts  Int           @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sentAt])
}
