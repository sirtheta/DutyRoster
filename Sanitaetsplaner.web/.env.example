# ── Database ──────────────────────────────────────────────────────────────────
# Overridden by docker-compose (file:/app/data/...)
DATABASE_URL="file:./data/sanitaetsplaner.db"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Random secret (min. 32 chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Optional in Docker: if unset, a random secret is generated on first start
# and persisted in the data volume (data/secrets.json).
# AUTH_SECRET="..."

# URL of the application (for redirects after login)
AUTH_URL="https://sanitaet.deine-domain.ch"

# ── Encryption (SMTP password & Telegram token in the DB) ────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Optional in Docker: if unset, a random key is generated on first start
# and persisted in the data volume (data/secrets.json).
# ENCRYPTION_KEY="..."

# Session duration in seconds (default: 8h)
# SESSION_MAX_AGE_SEC=28800
# SESSION_UPDATE_AGE_SEC=3600

# ── First admin user (created automatically at startup if no users exist)
# ADMIN_EMAIL="admin@example.com"
# ADMIN_NAME="Admin"
# ADMIN_PASSWORD="sicheres-passwort"
# or directly as a hash (bcrypt, cost 10):
# ADMIN_PASSWORD_HASH="$2b$10$..."

# ── Holidays: initial seeding ─────────────────────────────────────────────────
# ISO canton code for date-holidays (e.g. ZH, BE, ...)
DEFAULT_CANTON="BE"

# ── Automation / rotation ─────────────────────────────────────────────────────
# Default block size (number of consecutive days) for the yearly automation
# ROTATION_BLOCK_SIZE=5

# ── Notifications ─────────────────────────────────────────────────────────────
# Cron schedule for the hourly check of due notifications
NOTIFY_CRON_SCHEDULE="0 * * * *"

# ── Security / rate limiting ──────────────────────────────────────────────────
# RATE_LIMIT_MAX_ATTEMPTS=5
# RATE_LIMIT_WINDOW_MS=900000
# BCRYPT_ROUNDS=10

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info

# ── Development / staging ─────────────────────────────────────────────────────
# DISABLE_EMAIL=true
# DISABLE_TELEGRAM=true
